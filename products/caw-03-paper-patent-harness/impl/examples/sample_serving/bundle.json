      ]
    },
    {
      "claim_id": "s2",
      "type": "P1",
      "boundary": "public",
      "visibility": "team",
      "statement": "A latency-aware admission controller that briefly defers low-priority requests during load bursts keeps p99 latency within the service-level objective, sharply reducing SLO violations under bursty arrivals.",
