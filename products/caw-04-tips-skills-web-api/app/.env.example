# Local dev defaults to SQLite; set a postgres:// connection string for production.
DATABASE_URI=file:./caw04.db
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ── AI digest intro (optional) ───────────────────────────────────────────────
# AI_PROVIDER=openai | cli   (unset = deterministic intro, no AI call)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # any OpenAI-compatible endpoint
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=cli
# AI_CLI_COMMAND=codex exec -    # a CLI that reads the prompt on stdin, prints result on stdout
# AI_CLI_TIMEOUT_MS=60000

# ── Newsletter delivery via n8n (optional) ───────────────────────────────────
# Digest send POSTs { subject, summary, articleId, articleSlug, recipients } to this
# n8n webhook, which performs the actual email delivery (webhook + MCP workflow).
# N8N_WEBHOOK_URL=https://n8n.example.com/webhook/caw04-digest
# N8N_WEBHOOK_TOKEN=optional-bearer-token
