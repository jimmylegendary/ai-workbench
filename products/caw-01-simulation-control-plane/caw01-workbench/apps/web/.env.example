# ============================================================================
# CAW-01 web app — environment / infra config
# Copy this file to `.env.local` (same folder) and fill the values you need.
# `.env.local` is gitignored and auto-loaded by Next.js. Restart `next dev`
# after changing it.
#
# LOCAL MODE: if the Supabase block below is left EMPTY, the app runs fully
# locally with NO login gate (User/Settings persist to your browser's
# localStorage). Fill Supabase later to turn on real auth + persistence.
# ============================================================================

# --- Supabase (auth + Postgres + RLS) ---------------------------------------
# Leave EMPTY for local mode (no login). When you create a Supabase project,
# paste its values here, run `cd packages/db && supabase db push`, then restart.
#   NEXT_PUBLIC_*  → sent to the browser (RLS-guarded, safe to expose).
#   SERVICE_ROLE   → SERVER ONLY. Never expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth preview escape hatch ----------------------------------------------
# Set to 1 to bypass the login gate EVEN when Supabase env is filled (handy for
# previewing). Leave empty/0 for normal behavior. NEVER set in a real deploy.
PREVIEW_NO_AUTH=

# --- Simulation engine (Python service; behind a port/adapter) --------------
# Base URL of the simulation engine the workbench drives. Optional — runs/results
# are synthesized until this is wired. The Settings page "Test" button pings it.
ENGINE_BASE_URL=http://localhost:8000

# --- AI report backend (Sim Result → "Generate report") ---------------------
# Pick ONE backend. If unset/none, the app returns a deterministic templated
# report so the feature always works. Secrets are read SERVER-SIDE only.
#   openai       → OpenAI-compatible HTTP API (OpenAI / Azure / vLLM / OpenRouter / local gateway)
#   claude-cli   → spawns the `claude` CLI on the server's PATH (Claude Code headless)
#   openclaw-cli → spawns the `openclaw` CLI on the server's PATH
#   none         → templated fallback (no external call)
AI_BACKEND=none

# Used when AI_BACKEND=openai:
OPENAI_API_KEY=
OPENAI_BASEURL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# Optional: override CLI binary paths if not on PATH (claude-cli / openclaw-cli):
# CLAUDE_BIN=claude
# OPENCLAW_BIN=openclaw
