# Copy to apps/web/.env.local and fill. See design/06-frontend/auth-and-supabase.md §5.

# Supabase (browser — RLS-guarded)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server only — @caw/core + engine callback; NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Python engine service (always behind a port from the web app's perspective)
ENGINE_BASE_URL=http://localhost:8000
